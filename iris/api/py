iris = IrisCore()

# Инициализация служебных параметров через короткую сессию
session = SessionLocal()
try:
    for param in ["last_archive_time", "last_reflect_time", "last_lesson_reflect_time"]:
        if not session.query(PersonalityState).filter_by(parameter=param).first():
            session.add(PersonalityState(parameter=param, value=0.0))
    session.commit()
finally:
    session.close()

# ----------------------------- ФОНОВЫЕ ПОТОКИ -----------------------------

def background_dynamics():
    while True:
        time.sleep(900)
        session = SessionLocal()
        try:
            iris.apply_decay(session)
            if iris.silent_mode and iris.silent_until and datetime.datetime.now(datetime.UTC) >= iris.silent_until:
                iris.silent_mode = False
            if datetime.datetime.now(datetime.UTC).hour == 0:
                iris.ritual_asked_today = False
        except Exception:
            logging.exception("Decay error")
        finally:
            session.close()

def background_autonomous():
    while True:
        time.sleep(900)
        session = SessionLocal()
        try:
            if iris.silent_mode or iris.shadow_mode:
                continue

            # Рефлексия уроков раз в 12 часов
            last_reflect = session.query(PersonalityState).filter_by(parameter="last_lesson_reflect_time").first()
            now_ts = datetime.datetime.now(datetime.UTC).timestamp()
            if not last_reflect or (now_ts - last_reflect.value) > 43200:
                if last_reflect:
                    last_reflect.value = now_ts
                else:
                    session.add(PersonalityState(parameter="last_lesson_reflect_time", value=now_ts))
                session.commit()
                iris.reflect_on_incidents(session)

            # Автономное действие при простое
            last_msg = iris.last_user_message_time
            if last_msg is None or (datetime.datetime.now(datetime.UTC) - last_msg).total_seconds() > 600:
                iris.autonomous_action(session)
        except Exception:
            logging.exception("Autonomous error")
        finally:
            session.close()

def background_monitor():
    """Раз в час проверяет активные цели."""
    while True:
        time.sleep(3600)
        session = SessionLocal()
        try:
            iris._monitor_progress(session)
        except Exception:
            logging.exception("Monitor error")
        finally:
            session.close()

def background_planner():
    """Раз в 6 часов пересматривает стратегию."""
    while True:
        time.sleep(21600)
        session = SessionLocal()
        try:
            active_goals = session.query(Project).filter_by(status="active").all()
            for goal in active_goals:
                iris._plan_next_step(goal.id, session)
        except Exception:
            logging.exception("Planner error")
        finally:
            session.close()

def background_thinker(iris):
    """Безопасный фоновый мыслитель."""
    while not iris._bg_stop:
        for _ in range(iris.background_thinking_interval):
            if iris._bg_stop:
                return
            time.sleep(1)
        try:
            iris.experience_processor.process()
        except Exception:
            logging.exception("Thinker error")

threading.Thread(target=background_dynamics, daemon=True).start()
threading.Thread(target=background_autonomous, daemon=True).start()
threading.Thread(target=background_monitor, daemon=True).start()
threading.Thread(target=background_planner, daemon=True).start()
threading.Thread(target=background_thinker, args=(iris,), daemon=True).start()

