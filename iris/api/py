@app.get("/studio/list")
async def studio_list():
    files = []
    for f in IRIS_STUDIO_PATH.rglob("*"):
        if f.is_file() and "games" not in f.parts:
            files.append({"name": f.relative_to(IRIS_STUDIO_PATH).as_posix()})
    return {"files": files}

@app.get("/studio/view")
async def studio_view(name: str):
    filepath = IRIS_STUDIO_PATH / name
    if not filepath.exists():
        return "Файл не найден"
    return filepath.read_text(encoding="utf-8")

@app.post("/studio/run")
async def studio_run(request: Request):
    data = await request.json()
    name = data.get("name", "")
    code = data.get("code", "")
    if name:
        filepath = IRIS_STUDIO_PATH / name
        if not filepath.exists():
            return {"result": "❌ Файл не найден."}
        env = os.environ.copy()
        env["PYTHONIOENCODING"] = "utf-8"
        try:
            result = subprocess.run([sys.executable, str(filepath)], capture_output=True, text=True, timeout=10, encoding="utf-8", errors="replace", env=env)
            return {"result": f"✅ Выполнено:\n{(result.stdout or result.stderr)[:500]}"}
        except subprocess.TimeoutExpired:
            return {"result": "❌ Слишком долго."}
        except Exception as e:
            return {"result": f"❌ Ошибка: {e}"}
    elif code:
        env = os.environ.copy()
        env["PYTHONIOENCODING"] = "utf-8"
        try:
            result = subprocess.run([sys.executable, "-c", code], capture_output=True, text=True, timeout=10, encoding="utf-8", errors="replace", env=env)
            out = (result.stdout or result.stderr)[:500]
            return {"result": f"✅ Выполнено:\n{out}"}
        except subprocess.TimeoutExpired:
            return {"result": "❌ Слишком долго."}
        except Exception as e:
            return {"result": f"❌ Ошибка: {e}"}
    else:
        return {"result": "❌ Не указан ни файл, ни код."}

@app.get("/games/list")
async def games_list():
    games = []
    games_root = IRIS_STUDIO_PATH / "games"
    if games_root.exists():
        for d in games_root.iterdir():
            if d.is_dir() and (d / "scenario.json").exists():
                st = iris.get_game_status(d.name)
                if st:
                    games.append(st)
    return {"files": games}

@app.get("/games/{game_name}/play")
async def game_play(game_name: str):
    engine = iris.load_game_engine(game_name)
    view = engine.get_current_view()
    return JSONResponse(view)

@app.get("/games/{game_name}/action")
async def game_action(game_name: str, choice: int = 0):
    engine = iris.load_game_engine(game_name)
    result = engine.process_choice(choice)
    return JSONResponse(result if result else engine.get_current_view())

@app.post("/games/{game_name}/restart")
async def game_restart(game_name: str):
    engine = iris.load_game_engine(game_name)
    view = engine.restart()
    return JSONResponse(view)

@app.post("/clear_memory")
async def clear_memory():
    session = SessionLocal()
    try:
        session.query(Message).filter(
            Message.timestamp >= datetime.datetime.now(datetime.UTC) - datetime.timedelta(hours=24)
        ).delete()
        session.commit()
        iris.context = []
    finally:
        session.close()
    return {"status": "ok"}

if __name__ == "__main__":
    iris._record_presence("APP_STARTED", "Сервер запущен")

    def on_shutdown():
        try:
            db = SessionLocal()
            entry = PresenceLog(event_type="APP_CLOSED", details="Сервер остановлен")
            db.add(entry)
            db.commit()
            db.close()
        except Exception:
            logging.exception("Ошибка при записи PresenceLog")

    atexit.register(on_shutdown)

    def shutdown():
        iris._bg_stop = True

    atexit.register(shutdown)

    uvicorn.run(app, host="127.0.0.1", port=5000, log_level="info")
