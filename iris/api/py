@app.post("/chat")
async def chat_endpoint(request: Request):
    data = await request.json()
    user_msg = data.get("message", "")
    if not user_msg:
        return JSONResponse({"reply": "Я слушаю..."})
    return JSONResponse({"reply": iris.chat(user_msg)})

@app.post("/vision")
async def vision_endpoint(file: UploadFile = File(...), prompt: str = Form("Что изображено на этой картинке?")):
    image_bytes = await file.read()
    image_b64 = base64.b64encode(image_bytes).decode("utf-8")
    ext = file.filename.split(".")[-1].lower() if file.filename else "jpg"
    mime = {"jpg": "jpeg", "jpeg": "jpeg", "png": "png", "webp": "webp", "gif": "gif"}.get(ext, "jpeg")
    data_url = f"data:image/{mime};base64,{image_b64}"
    result = iris.vision_query(data_url, prompt)
    return JSONResponse({"reply": result})

